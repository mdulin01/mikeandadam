rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null &&
        request.auth.token.email in ['mdulin@gmail.com', 'adamjosephbritten@gmail.com'];
    }

    // ⚠️ trip-planner-5cc84 is SHARED by mikeandadam AND mikesfitness — these
    // rules govern both. Catch-all locks the whole project (tripData + its
    // subcollections, fitness collections, rupert, portal_*, dailyMetrics…)
    // to Mike + Adam. Before 2026-07-05 this was `request.auth != null`,
    // i.e. ANY signed-in Google account had full read/write.
    match /{document=**} {
      allow read, write: if isOwner();
    }

    // Guest event pages: public read + collaboration-field-only writes.
    // Owners keep full access via the catch-all (rules are OR'd).
    // Guests can no longer rewrite or delete whole event docs.
    match /events/{eventId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['guests', 'lists', 'images', 'photos', 'lastUpdated', 'updatedBy']);
    }
  }
}
